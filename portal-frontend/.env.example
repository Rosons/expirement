# 开发：留空则请求相对路径 /v1/ai、/v2/ai，由 vite.config 代理到后端（避免 CORS、端口不一致）
# 直连后端（不用代理）时再填：http://localhost:8080
VITE_API_BASE=

# 聊天 API：v1 | v2（对应 /v1/ai/chat 与 /v2/ai/chat）
VITE_CHAT_API_VERSION=v1

# v1 / v2 /history 共用：页码、每页条数（历史方向由前端固定为 order=desc）
# VITE_CHAT_HISTORY_PAGE=1
# VITE_CHAT_HISTORY_PAGE_SIZE=100
