# =============================================================================
# expirement Docker Compose 环境变量示例
# 使用方式：复制为 .env 后按需修改，再执行 docker compose up -d --build
#   Windows:  copy .env.example .env
#   Linux/macOS: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 对外端口（宿主机）
# -----------------------------------------------------------------------------
# 门户 / 静态站点 + API 反代（nginx）
FRONTEND_HTTP_PORT=80

# Spring Boot 直连端口（调试或绕过 nginx 调 API）；与容器内 8080 映射
BACKEND_HTTP_PORT=8080

# PostgreSQL 是否映射到宿主机；仅本机工具连库时需要，生产可改为不映射（需改 compose）
POSTGRES_PUBLISH_PORT=5432

# -----------------------------------------------------------------------------
# PostgreSQL（与 application.yaml 中 spring.datasource 一致）
# -----------------------------------------------------------------------------
DB_NAME=spring_ai_demo
DB_USERNAME=postgres
DB_PASSWORD=password

# 镜像标签（一般无需修改）
POSTGRES_IMAGE_TAG=16-alpine

# -----------------------------------------------------------------------------
# 大模型 / Spring AI（覆盖 application.yaml 中 spring.ai.openai.*）
# 切勿将真实 Key 提交到 Git；部署时在 .env 中填写
# -----------------------------------------------------------------------------
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=glm-4.7
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=text-embedding-v3
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_DIMENSIONS=1024

# 业务配置（对应 application.yaml 中 app.*）
APP_MULTIMODAL_MODEL_NAME=qwen3.5-omni-flash
APP_KNOWLEDGE_CHAT_RAG_SIMILARITY_THRESHOLD=0.5
APP_KNOWLEDGE_CHAT_RAG_TOP_K=3

# JVM 附加参数，例如内存：-Xms256m -Xmx512m
JAVA_TOOL_OPTIONS=

# -----------------------------------------------------------------------------
# 前端构建参数（Vite，仅在 docker compose build 阶段生效）
# 与 portal-frontend/src/api/env.ts 一致
# -----------------------------------------------------------------------------
# 留空：浏览器请求相对路径，由本仓库 nginx 反代到后端（推荐）
# 若前后端不同域，可填完整后端根 URL，例如 https://api.example.com
VITE_API_BASE=

# 聊天接口版本：v1 | v2（对应 /v1/ai/chat 与 /v2/ai/chat）
VITE_CHAT_API_VERSION=v2

# 历史记录分页默认页码与每页条数（1~200）
VITE_CHAT_HISTORY_PAGE=1
VITE_CHAT_HISTORY_PAGE_SIZE=10
